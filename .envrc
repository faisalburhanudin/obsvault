# Project-local Taskwarrior configuration
# Requires direnv: https://direnv.net/
# Run: direnv allow

export TASKDATA="$PWD/.pi/task"

# Optional: Create task directory if it doesn't exist
if [ ! -d "$TASKDATA" ]; then
    mkdir -p "$TASKDATA"
fi

# Optional: Create local taskrc if it doesn't exist
if [ ! -f "$TASKDATA/taskrc" ]; then
    touch "$TASKDATA/taskrc"
fi

echo "Taskwarrior: using project-local storage ($TASKDATA)"
